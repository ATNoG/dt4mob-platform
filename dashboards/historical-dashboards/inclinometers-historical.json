          "refId": "A",
          "root_selector": "(\n  $dados := $map(\n    $filter($, function($v) {\n      $contains($v.path, \"/properties/latestValue\") and\n      $contains($v.path, \"DispX\")\n    }),\n    function($v) {\n      {\n        \"time\": $substringBefore($v.time, \"T\"),\n        \"valor\": $number($v.value.valor),\n        \"disp_num\": $number(\n          $substringBefore($substringAfter($v.path, \"DispX\"), \"/\")\n        ),\n        \"path\": $v.path\n      }\n    }\n  );\n\n  $datas := $sort($distinct($dados.time));\n  $data_antiga  := $datas[0];\n  $data_recente := $datas[-1];\n\n  $append(\n    $map(\n      $distinct($dados.disp_num),\n      function($d) {\n        (\n          $reg_recente := $filter($dados, function($r) { $r.time = $data_recente and $r.disp_num = $d })[0];\n          $reg_antigo  := $filter($dados, function($r) { $r.time = $data_antiga  and $r.disp_num = $d })[0];\n      {\n          \"disp_num\":       $d,\n          \"time_recente\":   $reg_recente.time,\n          \"valor_recente\":  $reg_recente.valor,\n          \"time_antigo\":    $reg_antigo.time,\n          \"valor_antigo\":   $reg_antigo.valor,\n          \"valor\": $number($reg_recente.valor) - $number($reg_antigo.valor),\n          \"path\": \"Displacement (mm)\"\n        }\n        )\n      }\n  ),\n    [\n      { \"valor\": -15, \"path\": \"Alert 1\",         \"disp_num\": 0  },\n      { \"valor\": -15, \"path\": \"Alert 1\",         \"disp_num\": 40 },\n      { \"valor\":  15, \"path\": \"Alert 2\",        \"disp_num\": 0  },\n      { \"valor\":  15, \"path\": \"Alert 2\",        \"disp_num\": 40 },\n      { \"valor\": -20, \"path\": \"Alarm 1\",  \"disp_num\": 0  },\n      { \"valor\": -20, \"path\": \"Alarm 1\",  \"disp_num\": 40 },\n      { \"valor\":  20, \"path\": \"Alarm 2\", \"disp_num\": 0  },\n      { \"valor\":  20, \"path\": \"Alarm 2\", \"disp_num\": 40 }\n    ]\n)\n)",
          "source": "url",
          "type": "json",
